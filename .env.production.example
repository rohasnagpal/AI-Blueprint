AI_BLUEPRINT_ENV=production
AI_BLUEPRINT_RUN_MIGRATIONS_ON_STARTUP=false
AI_BLUEPRINT_SECURE_COOKIES=true
AI_BLUEPRINT_CORS_ORIGINS=https://your-domain.example
AI_BLUEPRINT_DATABASE_URL=sqlite:////data/ai_blueprint_v2.db
AI_BLUEPRINT_LEGACY_DATABASE_PATH=/data/ai_blueprint.db
AI_BLUEPRINT_UPLOADS_DIR=/uploads
AI_BLUEPRINT_SECRET_KEY_FILE=/keys/ai_blueprint_v2.key
AI_BLUEPRINT_LEGACY_SECRET_KEY_FILE=/keys/ai_blueprint_legacy.key
AI_BLUEPRINT_AUTH_RATE_LIMIT_ATTEMPTS=10
AI_BLUEPRINT_AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AI_BLUEPRINT_MAX_UPLOAD_BYTES=26214400
